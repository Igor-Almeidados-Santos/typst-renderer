      },
      "content": "// logger.js (core)\n\nexport function createLogger() {\n  let nextId = 1;               // estado privado\n  const events = [];            // estado privado (array)\n\n  function log(message) {\n    if (typeof message !== \"string\" || message.trim() === \"\") {\n      throw new TypeError(\"message deve ser string não vazia\");\n    }\n    const entry = { id: nextId++, message, at: Date.now() };\n    events.push(entry);\n    return entry.id;\n  }\n\n  function list() {\n    // retorna cópia rasa para evitar mutação externa do array\n    return events.slice();\n  }\n\n  function clear() {\n    events.length = 0;\n  }\n\n  return { log, list, clear };\n}\n\n// Uso:\n// const logger = createLogger();\n// logger.log('ok');\n// console.log(logger.list());",
