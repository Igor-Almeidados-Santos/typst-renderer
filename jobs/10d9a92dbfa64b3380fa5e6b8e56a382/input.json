      "content": "// core/searchText.js\n\nexport function normalizeQuery(raw) {\n  const s = String(raw)\n    .trim()\n    .normalize('NFC')\n    .replace(/\\s+/g, ' ');\n\n  if (s.length < 2) throw new Error('termo deve ter ao menos 2 caracteres');\n  return s;\n}\n\nexport function queryKey(raw) {\n  return normalizeQuery(raw).toLowerCase();\n}\n\nexport function slugify(raw) {\n  const s = normalizeQuery(raw)\n    .normalize('NFD')\n    .replace(/\\p{Diacritic}/gu, '')\n    .toLowerCase()\n    .replace(/[^a-z0-9\\s-]/g, '')\n    .replace(/\\s+/g, '-')\n    .replace(/-+/g, '-')\n    .replace(/^-|-$/g, '');\n\n  if (s === '') throw new Error('slug vazio');\n  return s;\n}",
