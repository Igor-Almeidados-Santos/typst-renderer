      "content": "// ui/searchForm.js (browser)\nimport { normalizeQuery, queryKey, slugify } from './core/searchText.js';\n\nfunction buildSearchUrl(term) {\n  const u = new URL('/search', window.location.origin);\n  u.searchParams.set('q', term);\n  u.searchParams.set('slug', slugify(term));\n  return u.toString();\n}\n\nfunction mockSearchResults(key) {\n  // mock: em projeto real, isso seria fetch\n  return [\n    `Resultado para: ${key}`,\n    `Sugestão: ${key}-1`,\n    `Sugestão: ${key}-2`,\n  ];\n}\n\nfunction renderList(ul, items) {\n  ul.replaceChildren();\n  for (const text of items) {\n    const li = document.createElement('li');\n    li.textContent = text; // seguro\n    ul.appendChild(li);\n  }\n}\n\nexport function wireSearchForm(formSelector, listSelector, outUrlSelector) {\n  const form = document.querySelector(formSelector);\n  const ul = document.querySelector(listSelector);\n  const outUrl = document.querySelector(outUrlSelector);\n\n  if (!form || !ul || !outUrl) throw new Error('elementos não encontrados');\n\n  form.addEventListener('submit', (ev) => {\n    ev.preventDefault();\n\n    const raw = new FormData(form).get('q');\n    const term = normalizeQuery(raw);\n    const key = queryKey(term);\n\n    const url = buildSearchUrl(term);\n    outUrl.textContent = url;\n\n    const results = mockSearchResults(key);\n    renderList(ul, results);\n  });\n}",
