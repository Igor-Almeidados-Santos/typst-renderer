      "lang": "javascript",
      "content": "'use strict';\n\nlet s = '  Ana  ';\nconst t = s.trim();\n\nconsole.log(s); // '  Ana  ' (nao mudou)\nconsole.log(t); // 'Ana'\n\ns = s.trim(); // reatribuicao\nconsole.log(s); // 'Ana'",
