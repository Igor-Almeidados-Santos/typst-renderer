      "lang": "javascript",
      "content": "console.log(!true);  // false\nconsole.log(!0);     // true\nconsole.log(!'');    // true\nconsole.log(!'abc'); // false\n\nconsole.log(!!'abc'); // true\nconsole.log(!!0);     // false\nconsole.log(!![]);    // true",
