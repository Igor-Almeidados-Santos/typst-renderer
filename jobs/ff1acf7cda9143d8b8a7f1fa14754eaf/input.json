      "type": "code",
      "lang": "javascript",
      "content": "console.log('' || 'padrão'); // 'padrão'\nconsole.log(0 || 99);        // 99 (pegadinha: 0 é falsy)\nconsole.log('ok' || 99);     // 'ok'",
