    {
      "type": "heading",
      "level": 2,
      "text": "2) Captura e bubbling (como o evento viaja)"
    },
    {
      "type": "list",
      "items": [
        "Capture: de cima para baixo (document → alvo).",
        "Target: no alvo.",
        "Bubbling: de baixo para cima (alvo → document).",
        "Por padrão, addEventListener usa bubbling (capture=false)."
      ]
    },
