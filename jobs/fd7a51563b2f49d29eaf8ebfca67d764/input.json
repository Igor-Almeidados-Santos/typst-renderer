    {
      "type": "heading",
      "level": 2,
      "text": "2) Montar query string manualmente (com segurança)"
    },
    {
      "type": "code",
      "lang": "javascript",
      "content": "function montarBusca(baseUrl, params) {\n  const pares = [];\n  for (const [k, v] of Object.entries(params)) {\n    const key = encodeURIComponent(k);\n    const val = encodeURIComponent(String(v));\n    pares.push(`${key}=${val}`);\n  }\n  const qs = pares.join('&');\n  return qs.length ? `${baseUrl}?${qs}` : baseUrl;\n}\n\nconsole.log(montarBusca('/produtos', { q: 'café com leite', page: 2 }));",
