    {
      "type": "heading",
      "level": 2,
      "text": "3) parse e stringify (modelo mental)"
    },
    {
      "type": "paragraph",
      "text": "JSON.parse transforma texto em dados. JSON.stringify transforma dados em texto. stringify só representa tipos suportados por JSON: undefined em objeto é omitido; em array vira null."
    },
