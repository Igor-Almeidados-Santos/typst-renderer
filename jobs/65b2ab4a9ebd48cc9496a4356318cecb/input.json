      "lang": "javascript",
      "content": "'use strict';\n\nconst ok = `{\"nome\":\"Ana\",\"idade\":20,\"vip\":true,\"tags\":[\"js\",\"web\"],\"apelido\":null}`;\nconsole.log(JSON.parse(ok));\n\nconst bad1 = \"{'nome':'Ana'}\";\nconst bad2 = `{\"nome\":\"Ana\",}`;\n\ntry { JSON.parse(bad1); } catch (e) { console.log('bad1:', e.message); }\ntry { JSON.parse(bad2); } catch (e) { console.log('bad2:', e.message); }",
