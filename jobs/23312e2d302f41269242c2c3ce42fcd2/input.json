      "content": "const u = new URL('https://exemplo.com/produtos?q=joao%20silva&page=0&tag=a&tag=b');\n\nconsole.log(u.pathname); // '/produtos'\nconsole.log(u.searchParams.get('q'));    // 'joao silva'\nconsole.log(u.searchParams.get('page')); // '0'\nconsole.log(u.searchParams.getAll('tag')); // ['a','b']\n\n// Construindo query com encoding correto\nconst params = new URLSearchParams();\nparams.set('q', 'a&b=c');\nparams.set('page', '1');\nconsole.log(params.toString()); // 'q=a%26b%3Dc&page=1'",
