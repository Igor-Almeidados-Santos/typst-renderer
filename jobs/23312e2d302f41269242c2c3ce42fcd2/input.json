        "function": null,
        "operator": null,
        "plain": null
      },
      "content": "export function normalizarNome(raw) {\n  const s = String(raw).trim().normalize('NFC');\n  // compacta espaços internos: 'João   da   Silva' -> 'João da Silva'\n  return s.replace(/\\s+/g, ' ');\n}\n\nexport function chaveNome(raw) {\n  // chave para deduplicação/busca case-insensitive\n  return normalizarNome(raw).toLowerCase();\n}\n\nconsole.log(normalizarNome('  João   da  Silva  '));\nconsole.log(chaveNome('joão da silva')); // pode vir com combining",
