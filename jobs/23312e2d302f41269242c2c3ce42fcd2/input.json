      "content": "// Regex pragmática: não perfeita, mas útil.\nconst RE_EMAIL = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n\nexport function emailPlausivel(raw) {\n  const s = String(raw).trim();\n  return RE_EMAIL.test(s);\n}\n\nconsole.log(emailPlausivel('ana@exemplo.com')); // true\nconsole.log(emailPlausivel('ana@exemplo'));     // false\nconsole.log(emailPlausivel(' ana@x.com '));     // true",
