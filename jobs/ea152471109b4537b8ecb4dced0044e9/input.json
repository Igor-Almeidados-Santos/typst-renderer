    {
      "type": "code",
      "lang": "javascript",
      "content": "const contagem = { PAGO: 0, PENDENTE: 0, CANCELADO: 0, OUTRO: 0 };\n\nfor (let i = 0; i < pedidos.length; i = i + 1) {\n  const p = pedidos[i];\n  const s = p.status;\n\n  if (s === 'PAGO') contagem.PAGO = contagem.PAGO + 1;\n  else if (s === 'PENDENTE') contagem.PENDENTE = contagem.PENDENTE + 1;\n  else if (s === 'CANCELADO') contagem.CANCELADO = contagem.CANCELADO + 1;\n  else contagem.OUTRO = contagem.OUTRO + 1;\n}\n\nconsole.log(contagem);",
