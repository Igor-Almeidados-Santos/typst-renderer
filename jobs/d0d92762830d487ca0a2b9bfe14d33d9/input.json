      "lang": "javascript",
      "content": "'use strict';\n\nconst titulo = document.querySelector('#titulo');\nconst itens = document.querySelectorAll('.item');\n\nconsole.log(titulo);\nfor (const el of itens) {\n  console.log(el.textContent);\n}",
