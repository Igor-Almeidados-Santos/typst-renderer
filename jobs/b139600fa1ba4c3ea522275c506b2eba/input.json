      "type": "code",
      "lang": "javascript",
      "content": "/**\n * Atualiza o contador exibido na tela.\n * Efeito colateral: escreve no DOM.\n * @param {HTMLElement} elValor - Elemento que recebe o texto.\n * @param {number} valor - Número atual do contador.\n */\nfunction renderValor(elValor, valor) {\n  elValor.textContent = String(valor);\n}\n\n/**\n * Converte uma entrada (string) para número.\n * Retorna NaN se não for possível converter.\n * @param {string} input\n * @returns {number}\n */\nfunction parseNumero(input) {\n  return Number(input);\n}",
