    {
      "type": "heading",
      "level": 2,
      "text": "6. Alternativa: setTimeout recursivo (mais controlável)"
    },
    {
      "type": "code",
      "lang": "javascript",
      "content": "function loopComTimeout(count, delay) {\n  const start = Date.now();\n\n  function step(i) {\n    const elapsed = Date.now() - start;\n    console.log('step', i, 'elapsed(ms)=', elapsed);\n\n    if (i >= count) return;\n    setTimeout(() => step(i + 1), delay);\n  }\n\n  step(1);\n}\n\nloopComTimeout(5, 200);",
