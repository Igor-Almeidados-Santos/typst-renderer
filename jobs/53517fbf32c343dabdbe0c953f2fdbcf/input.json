      "type": "code",
      "lang": "javascript",
      "content": "const routeState = {\n  itens: { q: '', selectedId: null },\n  settings: {},\n};\n\nfunction setItensFilter(q) {\n  routeState.itens = { ...routeState.itens, q: String(q ?? '') };\n  scheduleSaveUi();\n  render();\n}\n\nfunction scheduleSaveUi() {\n  clearTimeout(scheduleSaveUi.id);\n  scheduleSaveUi.id = setTimeout(() => {\n    saveUi({ ...appState.ui, itensQ: routeState.itens.q });\n  }, 250);\n}\n",
