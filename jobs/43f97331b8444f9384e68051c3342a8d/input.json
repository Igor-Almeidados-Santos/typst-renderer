      "lang": "javascript",
      "content": "const user = {\n  id: 10,\n  nome: 'Ana',\n  ativo: true,\n};\n\nconsole.log(user.nome); // 'Ana'\nuser.ativo = false;\nuser.email = 'ana@exemplo.com';\n\nconsole.log(user);",
