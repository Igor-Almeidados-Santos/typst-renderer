      },
      "content": "// Antes (anti-pattern): aninhamento\nfunction criarUsuario(raw) {\n  if (raw) {\n    if (raw.name) {\n      if (raw.age) {\n        return { ok: true, user: { name: raw.name, age: raw.age } };\n      } else {\n        return { ok: false, error: \"age obrigatória\" };\n      }\n    } else {\n      return { ok: false, error: \"name obrigatório\" };\n    }\n  }\n  return { ok: false, error: \"input ausente\" };\n}",
