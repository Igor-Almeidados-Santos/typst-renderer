        "number": null,
        "function": null,
        "operator": null,
        "plain": null
      },
      "content": "// Depois: guard clauses + contrato explícito\nfunction criarUsuario2(raw) {\n  if (raw == null) return { ok: false, error: \"input ausente\" };\n  if (typeof raw.name !== \"string\" || raw.name.trim() === \"\") {\n    return { ok: false, error: \"name obrigatório\" };\n  }\n\n  // idade pode ser 0? Se não, ajuste o contrato.\n  const age = Number(String(raw.age).trim());\n  if (!Number.isFinite(age)) return { ok: false, error: \"age inválida\" };\n\n  return {\n    ok: true,\n    user: { name: raw.name.trim(), age },\n  };\n}",
