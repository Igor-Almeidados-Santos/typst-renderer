      "text": "4) Corrida: somente o último request vale (jobId + abort)"
    },
    {
      "type": "code",
      "lang": "javascript",
      "content": "let currentJobId = 0;\nlet currentController = null;\n\nasync function buscar(termo) {\n  if (currentController) currentController.abort();\n\n  currentJobId += 1;\n  const jobId = currentJobId;\n\n  const controller = new AbortController();\n  currentController = controller;\n\n  const url = `/api/busca?q=${encodeURIComponent(termo)}`;\n\n  let res;\n  try {\n    res = await fetchWithTimeout(url, { signal: controller.signal }, 4000);\n  } catch (e) {\n    if (e && e.name === 'AbortError') return; // ignorar cancelado\n    console.error(e);\n    return;\n  }\n\n  const data = await res.json().catch(() => null);\n\n  if (jobId !== currentJobId) return;\n  console.log('resultados:', data);\n}",
