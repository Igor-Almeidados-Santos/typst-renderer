    {
      "type": "heading",
      "level": 2,
      "text": "2) Timeout com AbortController (padrão recomendado)"
    },
    {
      "type": "code",
      "lang": "javascript",
      "content": "async function fetchWithTimeout(url, options = {}, ms = 8000) {\n  const controller = new AbortController();\n  const id = setTimeout(() => controller.abort(), ms);\n\n  try {\n    return await fetch(url, { ...options, signal: controller.signal });\n  } finally {\n    clearTimeout(id);\n  }\n}",
