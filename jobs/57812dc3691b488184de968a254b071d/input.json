    {
      "type": "heading",
      "level": 2,
      "text": "3) Separar erros: abort/rede vs status HTTP vs JSON inválido"
    },
    {
      "type": "code",
      "lang": "javascript",
      "content": "async function requestJson(url, options = {}, timeoutMs = 8000) {\n  let res;\n  try {\n    res = await fetchWithTimeout(url, options, timeoutMs);\n  } catch (e) {\n    if (e && e.name === 'AbortError') return { ok: false, msg: 'timeout/cancelado' };\n    return { ok: false, msg: 'erro de rede: ' + String(e?.message ?? e) };\n  }\n\n  const text = await res.text().catch(() => '');\n\n  if (!res.ok) {\n    return { ok: false, status: res.status, msg: text || res.statusText };\n  }\n\n  try {\n    return { ok: true, status: res.status, data: JSON.parse(text) };\n  } catch {\n    return { ok: false, status: res.status, msg: 'JSON inválido', raw: text };\n  }\n}",
