        "number": null,
        "function": null,
        "operator": null,
        "plain": null
      },
      "content": "console.log(NaN === NaN);          // false\nconsole.log(Object.is(NaN, NaN));  // true\n\nconsole.log(0 === -0);             // true\nconsole.log(Object.is(0, -0));     // false",
