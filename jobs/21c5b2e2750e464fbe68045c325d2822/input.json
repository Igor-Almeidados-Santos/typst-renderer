      "type": "heading",
      "level": 2,
      "text": "5) Map de rotas → render de tela"
    },
    {
      "type": "code",
      "lang": "javascript",
      "content": "function renderHome() {\n  return `<h2>Home</h2><p>Bem-vindo</p>`;\n}\n\nfunction renderTarefas() {\n  return `<h2>Tarefas</h2><p>...</p>`;\n}\n\nfunction renderSettings() {\n  return `<h2>Configurações</h2><p>...</p>`;\n}\n\nconst routes = {\n  '/': renderHome,\n  '/tarefas': renderTarefas,\n  '/settings': renderSettings,\n};\n\nfunction render() {\n  const root = document.querySelector('#app');\n  const fn = routes[state.route] ?? renderHome;\n  root.innerHTML = fn();\n}\n\nrender();",
