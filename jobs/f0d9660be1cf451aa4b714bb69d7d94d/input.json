      "lang": "javascript",
      "content": "{\n  const apiBase = 'https://exemplo.local';\n  const timeoutMs = 2000;\n  console.log('Config local:', apiBase, timeoutMs);\n}\n\n// apiBase não existe aqui — e isso é intencional.",
