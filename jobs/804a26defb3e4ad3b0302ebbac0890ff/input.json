      "content": "function aplicarDesconto(percentual) {\n  // Bug: 0% é válido, mas é falsy\n  if (!percentual) throw new Error(\"percentual obrigatório\");\n  return `Desconto: ${percentual}%`;\n}\n\n// aplicarDesconto(0) -> erro, mas 0 é entrada válida\n\nfunction aplicarDescontoSeguro(percentual) {\n  // Contrato explícito: null/undefined são ausência; 0 é válido\n  if (percentual == null) throw new Error(\"percentual obrigatório\");\n  if (typeof percentual !== \"number\") throw new TypeError(\"percentual deve ser number\");\n  return `Desconto: ${percentual}%`;\n}\n\nconsole.log(aplicarDescontoSeguro(0));",
