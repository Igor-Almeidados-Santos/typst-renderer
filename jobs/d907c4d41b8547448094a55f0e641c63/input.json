      "content": "// script-apressado.js (browser)\n\nasync function main() {\n  // Problema A (plataforma): CORS / origem / endpoint inexistente\n  const res = await fetch(\"https://api.exemplo.invalid/users\");\n\n  // Problema B (contrato): supor que sempre vem JSON válido\n  const users = await res.json();\n\n  // Problema C (runtime/ordem): supor que o DOM já está pronto\n  const ul = document.querySelector(\"#users\");\n\n  // Problema D (linguagem): supor forma do dado sem validar\n  ul.innerHTML = users.map(u => `<li>${u.id} - ${u.name.toUpperCase()}</li>`).join(\"\");\n}\n\nmain();",
