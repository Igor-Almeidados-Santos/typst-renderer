      "content": "async function obterUsuarios(url) {\n  const users = await obterJson(url);\n  return normalizarUsuarios(users);\n}\n\nfunction paraItens(users) {\n  return users.map(u => `${u.id} - ${u.name.toUpperCase()}`);\n}\n\nfunction renderizarLista(selector, itens) {\n  const ul = document.querySelector(selector);\n  if (!ul) throw new Error(`Elemento não encontrado: ${selector}`);\n  ul.innerHTML = itens.map(t => `<li>${t}</li>`).join(\"\");\n}\n\nasync function main() {\n  const users = await obterUsuarios(\"/api/users\");\n  const itens = paraItens(users);\n  renderizarLista(\"#users\", itens);\n}\n\nwindow.addEventListener(\"DOMContentLoaded\", () => {\n  main().catch(err => console.error(err));\n});",
