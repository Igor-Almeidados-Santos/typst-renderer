    {
      "type": "heading",
      "level": 2,
      "text": "3) Matching simples por segmentos"
    },
    {
      "type": "code",
      "lang": "javascript",
      "content": "function matchRoute(path) {\n  const seg = splitPath(path);\n\n  if (seg.length === 0) return { name: 'home', params: {} };\n\n  if (seg[0] === 'tarefas' && seg.length === 1) {\n    return { name: 'tarefas', params: {} };\n  }\n\n  if (seg[0] === 'tarefas' && seg.length === 2) {\n    const id = Number(seg[1]);\n    if (!Number.isFinite(id)) return { name: 'notfound', params: {} };\n    return { name: 'tarefaDetalhe', params: { id } };\n  }\n\n  if (seg[0] === 'settings' && seg.length === 1) {\n    return { name: 'settings', params: {} };\n  }\n\n  return { name: 'notfound', params: {} };\n}\n\nconsole.log(matchRoute('/tarefas/42'));\nconsole.log(matchRoute('/tarefas/x')); // notfound",
