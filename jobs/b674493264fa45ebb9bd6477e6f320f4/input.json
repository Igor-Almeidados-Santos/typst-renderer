      "content": "export function escapeHtml(raw) {\n  return String(raw)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#39;');\n}\n\n// Melhor: inserir como texto\n// el.textContent = userInput\n\n// Se gerar HTML:\n// el.innerHTML = `<span>${escapeHtml(userInput)}</span>`\n\nexport function toQueryParam(raw) {\n  return encodeURIComponent(String(raw));\n}\n\nconsole.log(toQueryParam('a&b=c')); // 'a%26b%3Dc'",
