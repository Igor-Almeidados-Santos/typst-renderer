          128
        ],
        "keyword": null,
        "string": null,
        "comment": null,
        "number": null,
        "function": null,
        "operator": null,
        "plain": null
      },
      "content": "export function slugify(raw) {\n  const s = String(raw)\n    .trim()\n    .normalize('NFD')\n    .replace(/\\p{Diacritic}/gu, '')\n    .toLowerCase()\n    .replace(/[^a-z0-9\\s-]/g, '')\n    .replace(/\\s+/g, '-')\n    .replace(/-+/g, '-')\n    .replace(/^-|-$/g, '');\n\n  if (s === '') throw new Error('slug vazio');\n  return s;\n}\n\nconsole.log(slugify('  João da Silva!  ')); // 'joao-da-silva'",
