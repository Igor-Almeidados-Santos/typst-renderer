      "content": "function calcularTotal(qtdRaw, precoRaw) {\n  const qtd = Number(String(qtdRaw).trim());\n  const preco = Number(String(precoRaw).trim());\n\n  // Valida cedo\n  if (Number.isNaN(qtd) || Number.isNaN(preco)) {\n    return { ok: false, msg: 'Entrada inválida: não é número.' };\n  }\n\n  if (qtd <= 0) {\n    return { ok: false, msg: 'Quantidade deve ser > 0.' };\n  }\n\n  if (preco < 0) {\n    return { ok: false, msg: 'Preço não pode ser negativo.' };\n  }\n\n  // A partir daqui, o estado é válido\n  const total = qtd * preco;\n  return { ok: true, total };\n}\n\nconsole.log(calcularTotal('2', '10'));\nconsole.log(calcularTotal('', '10'));\nconsole.log(calcularTotal('2', '-1'));",
