    {
      "type": "heading",
      "level": 2,
      "text": "4) test, match e replace"
    },
    {
      "type": "list",
      "items": [
        "test: true/false (validação).",
        "match: extrai detalhes (capturas).",
        "replace/replaceAll: transforma texto por padrão."
      ]
    },
