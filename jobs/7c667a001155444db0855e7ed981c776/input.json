      "content": "// core.js\n\nexport function stringNaoVazia(v, nome = \"valor\") {\n  if (v == null) throw new Error(`${nome} é obrigatório`);\n  if (typeof v !== \"string\") throw new TypeError(`${nome} deve ser string`);\n  const s = v.trim();\n  if (s === \"\") throw new Error(`${nome} não pode ser vazio`);\n  return s;\n}\n\nexport function parseIntFaixa(v, nome = \"valor\", min = 0, max = 130) {\n  const raw = typeof v === \"number\" ? String(v) : String(v);\n  const n = Number(raw.trim());\n  if (!Number.isFinite(n) || !Number.isInteger(n)) {\n    throw new TypeError(`${nome} deve ser inteiro (recebido: ${v})`);\n  }\n  if (n < min || n > max) {\n    throw new RangeError(`${nome} deve estar entre ${min} e ${max} (recebido: ${n})`);\n  }\n  return n;\n}\n\nexport function normalizarCadastro(input) {\n  if (input == null || typeof input !== \"object\") throw new TypeError(\"input inválido\");\n\n  const name = stringNaoVazia(input.name, \"nome\");\n  const age = parseIntFaixa(input.age, \"idade\", 0, 130);\n\n  // newsletter: opcional; se vier, converte para boolean\n  const newsletter = input.newsletter == null ? false : Boolean(input.newsletter);\n\n  return { name, age, newsletter };\n}",
