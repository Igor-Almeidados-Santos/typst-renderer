    {
      "type": "heading",
      "level": 2,
      "text": "6. Identificando tipos de objeto com segurança"
    },
    {
      "type": "list",
      "items": [
        "Array: Array.isArray(valor)",
        "Null: valor === null",
        "Date: valor instanceof Date",
        "Função: typeof valor === 'function'",
        "Objeto “puro”: typeof valor === 'object' && valor !== null && !Array.isArray(valor)"
      ]
    },
    {
      "type": "code",
      "lang": "javascript",
