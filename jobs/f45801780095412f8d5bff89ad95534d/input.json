      "type": "code",
      "lang": "javascript",
      "content": "const a = null;\nconst b = 'ok';\nconst c = true;\n\n// Intenção: usar b quando a for null/undefined, depois aplicar lógica\nconst r1 = (a ?? b) && c;\nconsole.log(r1); // 'ok'\n\n// Intenção: primeiro decidir c || b, depois usar como fallback\nconst r2 = a ?? (c || b);\nconsole.log(r2); // true",
