        ],
        [
          {
            "kind": "comment",
            "text": "// { ok: false, error: { code: 'INVALID_INPUT', message: '...' } }"
          }
        ]
      ]
    },
    {
      "type": "heading",
      "level": 2,
      "text": "3) Exemplo: payload de pedido (contrato simples)"
    },
