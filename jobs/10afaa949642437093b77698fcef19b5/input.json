    {
      "type": "heading",
      "level": 2,
      "text": "4) Consumidor robusto: validar e normalizar antes de usar"
    },
    {
      "type": "paragraph",
      "text": "A validação aqui é “mínima e suficiente”: confirmar formato geral, validar campos essenciais e normalizar tipos (número e data). Isso evita TypeError e bugs silenciosos."
    },
    {
      "type": "code",
      "lang": "javascript",
      "content": "'use strict';\n\nfunction toNumberOrNull(v) {\n  if (v === null || v === undefined) return null;\n  const n = (typeof v === 'number') ? v : Number(String(v).trim());\n  return Number.isNaN(n) ? null : n;\n}\n\nfunction toDateOrNull(v) {\n  if (v === null || v === undefined) return null;\n  const d = new Date(String(v));\n  return Number.isNaN(d.getTime()) ? null : d;\n}\n\nfunction parsePedidoResponse(jsonText) {\n  let root;\n  try { root = JSON.parse(jsonText); }\n  catch { return { ok: false, msg: 'JSON inválido' }; }\n\n  if (!root || typeof root !== 'object') return { ok: false, msg: 'resposta inválida' };\n  if (root.ok !== true) return { ok: false, msg: root?.error?.message ?? 'erro' };\n\n  const d = root.data;\n  if (!d || typeof d !== 'object') return { ok: false, msg: 'data inválido' };\n\n  const id = toNumberOrNull(d.id);\n  const total = toNumberOrNull(d.total);\n  const criadoEm = toDateOrNull(d.criadoEm);\n  const status = String(d.status ?? '').trim();\n\n  if (id === null) return { ok: false, msg: 'id inválido' };\n  if (total === null) return { ok: false, msg: 'total inválido' };\n  if (!criadoEm) return { ok: false, msg: 'criadoEm inválido' };\n  if (!status) return { ok: false, msg: 'status inválido' };\n\n  return { ok: true, pedido: { id, total, criadoEm, status } };\n}\n\nconst sample = '{\"ok\":true,\"data\":{\"id\":101,\"status\":\"PAGO\",\"total\":\"120.5\",\"criadoEm\":\"2026-01-01T10:00:00Z\"}}';\nconsole.log(parsePedidoResponse(sample));",
