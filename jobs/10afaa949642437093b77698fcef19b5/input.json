      "type": "code",
      "lang": "javascript",
      "content": "// GET /pedido/101\n// {\n//   \"ok\": true,\n//   \"data\": {\n//     \"id\": 101,\n//     \"status\": \"PAGO\",\n//     \"total\": 120.5,\n//     \"criadoEm\": \"2026-01-01T10:00:00Z\"\n//   }\n// }",
