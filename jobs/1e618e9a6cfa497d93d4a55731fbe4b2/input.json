      "type": "code",
      "lang": "javascript",
      "content": "function marcarFeitaImutavel(lista, id) {\n  return lista.map((t) => {\n    if (t.id !== id) return t;\n    return { ...t, done: true }; // novo objeto apenas aqui\n  });\n}\n\nconst b = marcarFeitaImutavel(tarefas, 1);\nconsole.log(tarefas); // original\nconsole.log(b);       // novo array\n\nconsole.log(tarefas === b); // false",
