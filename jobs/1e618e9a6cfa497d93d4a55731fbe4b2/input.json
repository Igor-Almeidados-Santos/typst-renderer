    {
      "type": "heading",
      "level": 2,
      "text": "2) find: encontrar um item (por id)"
    },
    {
      "type": "paragraph",
      "text": "find retorna o primeiro elemento que satisfaz o predicado, ou undefined se não encontrar."
    },
