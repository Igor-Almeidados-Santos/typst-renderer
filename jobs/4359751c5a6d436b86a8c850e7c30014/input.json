    {
      "type": "heading",
      "level": 2,
      "text": "2) JSON stringify/parse (limitado)"
    },
    {
      "type": "paragraph",
      "text": "JSON.parse(JSON.stringify(obj)) copia apenas dados representaveis em JSON. Perde undefined, function, Symbol, BigInt e transforma Date em string. Use apenas em objetos simples e controlados."
    },
    {
      "type": "code",
      "lang": "javascript",
