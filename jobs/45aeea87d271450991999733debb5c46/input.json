        "keyword": null,
        "string": null,
        "comment": null,
        "number": null,
        "function": null,
        "operator": null,
        "plain": null
      },
      "content": "const handlers = {\n  create: (raw) => {\n    const userId = assertStringNaoVazia(raw.userId, \"userId\");\n    const items = assertArrayNaoVazia(raw.items, \"items\");\n    return ok({ created: true, userId, itemsCount: items.length });\n  },\n\n  pay: (raw) => {\n    const orderId = assertStringNaoVazia(raw.orderId, \"orderId\");\n    const method = assertStringNaoVazia(raw.method, \"method\");\n    if (method !== \"pix\" && method !== \"card\") {\n      return fail(\"method deve ser pix ou card\");\n    }\n    return ok({ paid: true, orderId, method });\n  },\n\n  cancel: (raw) => {\n    const orderId = assertStringNaoVazia(raw.orderId, \"orderId\");\n    const reason = assertStringNaoVazia(raw.reason, \"reason\");\n    return ok({ canceled: true, orderId, reason });\n  },\n};\n\nfunction executar(raw) {\n  const v = validate(raw);\n  if (!v.ok) return v;\n\n  const { action, raw: input } = v.value;\n  const fn = handlers[action];\n  if (!fn) return fail(`ação desconhecida: ${action}`);\n\n  try {\n    return fn(input);\n  } catch (e) {\n    // contexto no boundary do pipeline\n    return fail(`falha ao executar ${action}: ${e.message}`);\n  }\n}",
