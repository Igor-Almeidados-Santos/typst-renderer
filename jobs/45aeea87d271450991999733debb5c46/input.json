        "operator": null,
        "plain": null
      },
      "content": "function ok(value) {\n  return { ok: true, value };\n}\n\nfunction fail(error) {\n  return { ok: false, error };\n}\n\nfunction assertPresent(v, nome) {\n  if (v == null) throw new Error(`${nome} é obrigatório`);\n  return v;\n}\n\nfunction assertStringNaoVazia(v, nome) {\n  const s = String(assertPresent(v, nome)).trim();\n  if (s === \"\") throw new Error(`${nome} não pode ser vazio`);\n  return s;\n}\n\nfunction assertArrayNaoVazia(v, nome) {\n  if (!Array.isArray(v) || v.length === 0) throw new Error(`${nome} deve ser array não vazio`);\n  return v;\n}\n\nfunction validate(raw) {\n  try {\n    const action = assertStringNaoVazia(raw?.action, \"action\");\n    return ok({ action, raw });\n  } catch (e) {\n    return fail(e.message);\n  }\n}",
